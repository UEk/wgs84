{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "declaration": true,
        "lib": ["ES2022", "dom"],
        "moduleResolution": "node16",
        "rootDir": "src",
        "outDir": "dist",
        "noImplicitAny": true,
        "sourceMap": true,
        "removeComments": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "noEmitOnError": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "coverage", "test", "example"]
}
